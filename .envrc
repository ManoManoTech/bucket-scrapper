#!/nix/store/rlq03x4cwf8zn73hxaxnx0zn5q9kifls-bash-5.3p3/bin/bash
set -o errexit
set -o nounset
set -o pipefail

# shellcheck disable=SC1091

# Watch nix files for changes
watch_file ./**/*.nix
watch_file ./*.nix
watch_file flake.lock

# PERF: Load nix-direnv for cached flake environments
source /nix/store/myrrn52p2p88wzmdrl2b2smkydxvf87g-nix-direnv-3.1.0/share/nix-direnv/direnvrc
use flake

# INFO: Load dotenv files with direnv watch support
dotenv_if_exists .env
dotenv_if_exists .env.local
if [[ -n "${ENV:-}" ]]; then
  dotenv_if_exists ".env.$ENV"
  dotenv_if_exists ".env.$ENV.local"
fi

