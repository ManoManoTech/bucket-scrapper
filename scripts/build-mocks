#!/usr/bin/env bash

set -euo pipefail

# Configuration
DATE="20231225"
HOUR="14"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
MOCKS_DIR="$PROJECT_ROOT/tests/mocks"
OUTPUT_DIR="$MOCKS_DIR/generated"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check dependencies
check_dependencies() {
    log "Checking dependencies..."
    
    if ! command -v gzip &> /dev/null; then
        error "gzip is required but not installed"
        exit 1
    fi
    
    if ! command -v zstd &> /dev/null; then
        error "zstd is required but not installed"
        exit 1
    fi
    
    log "Dependencies OK"
}

# Clean and create output directories
setup_directories() {
    log "Setting up directories..."
    
    rm -rf "$OUTPUT_DIR"
    mkdir -p "$OUTPUT_DIR"
    
    # Create input buckets structure (gzip format)
    mkdir -p "$OUTPUT_DIR/bucket-A/logs/$DATE/$HOUR"
    mkdir -p "$OUTPUT_DIR/bucket-B/datadog/dt=$DATE/h=$HOUR"  
    mkdir -p "$OUTPUT_DIR/bucket-C/logs/$DATE/$HOUR"
    
    # Create consolidated bucket structure (zstd format)
    mkdir -p "$OUTPUT_DIR/bucket-consolidated/log-archives/dt=$DATE/h=$HOUR"
    
    # Create checker results bucket
    mkdir -p "$OUTPUT_DIR/bucket-checker-results/check-results/dt=$DATE/h=$HOUR"
    
    log "Directories created"
}

# Process input bucket A (Vector-like logs)
process_bucket_A() {
    log "Processing bucket A (Vector-like logs)..."
    
    local input_dir="$MOCKS_DIR/inputs-A"
    local output_dir="$OUTPUT_DIR/bucket-A/logs/$DATE/$HOUR"
    
    if [ ! -d "$input_dir" ]; then
        error "Input directory not found: $input_dir"
        return 1
    fi
    
    # Process each log file
    for log_file in "$input_dir"/*.log; do
        if [ -f "$log_file" ]; then
            local filename=$(basename "$log_file")
            local zip_name="${filename%.log}.json.gz"
            
            # Create JSONLines format (no trailing newline for Vector)
            cat "$log_file" | gzip > "$output_dir/$zip_name"
            log "  Created: $zip_name"
        fi
    done
}

# Process input bucket B (Datadog-like logs)  
process_bucket_B() {
    log "Processing bucket B (Datadog-like logs)..."
    
    local input_dir="$MOCKS_DIR/inputs-B"
    local output_dir="$OUTPUT_DIR/bucket-B/datadog/dt=$DATE/h=$HOUR"
    
    if [ ! -d "$input_dir" ]; then
        error "Input directory not found: $input_dir"
        return 1
    fi
    
    # Process each log file
    for log_file in "$input_dir"/*.log; do
        if [ -f "$log_file" ]; then
            local filename=$(basename "$log_file")
            local zip_name="${filename%.log}.json.gz"
            
            # Create JSONLines format (WITH trailing newline for Datadog)
            (cat "$log_file"; echo) | gzip > "$output_dir/$zip_name"
            log "  Created: $zip_name"
        fi
    done
}

# Process input bucket C (Another source)
process_bucket_C() {
    log "Processing bucket C (Other source logs)..."
    
    local input_dir="$MOCKS_DIR/inputs-C"
    local output_dir="$OUTPUT_DIR/bucket-C/logs/$DATE/$HOUR"
    
    if [ ! -d "$input_dir" ]; then
        error "Input directory not found: $input_dir"
        return 1
    fi
    
    # Process each log file
    for log_file in "$input_dir"/*.log; do
        if [ -f "$log_file" ]; then
            local filename=$(basename "$log_file")
            local zip_name="${filename%.log}.json.gz"
            
            # Create JSONLines format (no trailing newline)
            cat "$log_file" | gzip > "$output_dir/$zip_name"
            log "  Created: $zip_name"
        fi
    done
}

# Create consolidated files (simulate consolidation by env-service)
create_consolidated_files() {
    log "Creating consolidated files..."
    
    local output_dir="$OUTPUT_DIR/bucket-consolidated/log-archives/dt=$DATE/h=$HOUR"
    local temp_dir="$OUTPUT_DIR/temp_consolidation"
    mkdir -p "$temp_dir"
    
    # Collect all logs and group by env-service
    declare -A env_service_logs
    
    # Process all input buckets
    for bucket_dir in "$MOCKS_DIR"/inputs-*; do
        if [ -d "$bucket_dir" ]; then
            for log_file in "$bucket_dir"/*.log; do
                if [ -f "$log_file" ]; then
                    # Extract env and service from JSON
                    local env=$(jq -r '.env // "unknown"' "$log_file")
                    local service=$(jq -r '.service // "unknown"' "$log_file")
                    local key="${env}-${service}"
                    
                    # Append to consolidated file
                    cat "$log_file" >> "$temp_dir/$key.jsonl"
                fi
            done
        fi
    done
    
    # Create zstd compressed consolidated files
    for jsonl_file in "$temp_dir"/*.jsonl; do
        if [ -f "$jsonl_file" ]; then
            local filename=$(basename "$jsonl_file" .jsonl)
            local zst_name="${filename}-consolidated.json.zst"
            
            zstd -q "$jsonl_file" -o "$output_dir/$zst_name"
            log "  Created consolidated: $zst_name"
        fi
    done
    
    # Cleanup
    rm -rf "$temp_dir"
}

# Create sample check results
create_check_results() {
    log "Creating sample check results..."
    
    local output_dir="$OUTPUT_DIR/bucket-checker-results/check-results/dt=$DATE/h=$HOUR"
    local result_file="$output_dir/check-result-${DATE}-${HOUR}.json"
    
    cat > "$result_file" << EOF
{
  "ok": true,
  "date": "$DATE",
  "hour": "$HOUR",
  "message": "Mock check completed successfully",
  "analysis_start_date": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "analysis_end_date": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "buckets_checked": ["bucket-A", "bucket-B", "bucket-C"],
  "files_processed": 7,
  "character_count_match": true
}
EOF
    
    log "  Created: check-result-${DATE}-${HOUR}.json"
}

# Display summary
show_summary() {
    log "Build complete! Generated structure:"
    echo
    find "$OUTPUT_DIR" -type f | sort | sed 's|^|  |'
    echo
    log "Mock data ready for testing in: $OUTPUT_DIR"
}

# Main execution
main() {
    log "Building mock data for log-consolidator-checker..."
    
    check_dependencies
    setup_directories
    process_bucket_A
    process_bucket_B  
    process_bucket_C
    create_consolidated_files
    create_check_results
    show_summary
    
    log "Mock build completed successfully!"
}

# Run main function
main "$@"